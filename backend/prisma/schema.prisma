// Gosandy Company Ltd - POS System
// Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  BOSS
  ADMIN
  STAFF
}

enum TransactionStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum ItemType {
  SERVICE
  STATIONERY
}

// ─────────────────────────────────────────────
// BRANCH
// ─────────────────────────────────────────────

model Branch {
  id          String   @id @default(uuid())
  name        String
  location    String
  phone       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users            User[]
  services         Service[]
  stationeryItems  StationeryItem[]
  transactions     Transaction[]
  stockMovements   StockMovement[]
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  fullName     String
  email        String   @unique
  phone        String?
  passwordHash String
  role         Role     @default(STAFF)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  branch       Branch?  @relation(fields: [branchId], references: [id])
  branchId     String?

  // Transactions this user recorded as staff
  transactionsAsStaff    Transaction[] @relation("StaffTransactions")
  // Transactions this user confirmed as cashier
  transactionsAsCashier  Transaction[] @relation("CashierTransactions")

  stockMovements  StockMovement[]
  receipts        Receipt[]
}

// ─────────────────────────────────────────────
// SERVICE CATALOG
// ─────────────────────────────────────────────

model Service {
  id          String   @id @default(uuid())
  name        String
  category    String   // e.g. "Printing", "Lamination", "Scanning"
  unitPrice   Decimal  @db.Decimal(10, 2)
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branch      Branch?  @relation(fields: [branchId], references: [id])
  branchId    String?  // null = global service available to all branches

  transactionItems  TransactionItem[]
}

// ─────────────────────────────────────────────
// STATIONERY INVENTORY
// ─────────────────────────────────────────────

model StationeryItem {
  id              String   @id @default(uuid())
  name            String
  unitPrice       Decimal  @db.Decimal(10, 2)
  quantityInStock Int      @default(0)
  lowStockAlert   Int      @default(5)  // alert when stock falls below this
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  branch      Branch   @relation(fields: [branchId], references: [id])
  branchId    String

  transactionItems  TransactionItem[]
  stockMovements    StockMovement[]
}

// ─────────────────────────────────────────────
// STOCK MOVEMENTS (audit trail for inventory)
// ─────────────────────────────────────────────

model StockMovement {
  id          String   @id @default(uuid())
  type        String   // "ADD" | "SALE" | "ADJUSTMENT"
  quantity    Int
  note        String?
  createdAt   DateTime @default(now())

  stationeryItem    StationeryItem @relation(fields: [stationeryItemId], references: [id])
  stationeryItemId  String

  branch    Branch @relation(fields: [branchId], references: [id])
  branchId  String

  recordedBy    User   @relation(fields: [recordedById], references: [id])
  recordedById  String
}

// ─────────────────────────────────────────────
// TRANSACTION (sale session)
// ─────────────────────────────────────────────

model Transaction {
  id              String            @id @default(uuid())
  customerName    String?
  totalAmount     Decimal           @db.Decimal(10, 2)
  amountPaid      Decimal?          @db.Decimal(10, 2)
  balance         Decimal?          @db.Decimal(10, 2)  // change given to customer
  status          TransactionStatus @default(PENDING)
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  confirmedAt     DateTime?

  branch      Branch @relation(fields: [branchId], references: [id])
  branchId    String

  staff       User   @relation("StaffTransactions", fields: [staffId], references: [id])
  staffId     String

  cashier     User?  @relation("CashierTransactions", fields: [cashierId], references: [id])
  cashierId   String?

  items    TransactionItem[]
  receipt  Receipt?
}

// ─────────────────────────────────────────────
// TRANSACTION ITEMS (line items per transaction)
// ─────────────────────────────────────────────

model TransactionItem {
  id          String   @id @default(uuid())
  itemType    ItemType
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  subtotal    Decimal  @db.Decimal(10, 2)
  itemName    String   // snapshot of name at time of sale

  transaction    Transaction @relation(fields: [transactionId], references: [id])
  transactionId  String

  // Linked to service OR stationery (only one will be set)
  service         Service?        @relation(fields: [serviceId], references: [id])
  serviceId       String?

  stationeryItem    StationeryItem? @relation(fields: [stationeryItemId], references: [id])
  stationeryItemId  String?
}

// ─────────────────────────────────────────────
// RECEIPT
// ─────────────────────────────────────────────

model Receipt {
  id          String   @id @default(uuid())
  receiptNo   String   @unique  // e.g. "GSY-00123"
  printedAt   DateTime @default(now())

  transaction    Transaction @relation(fields: [transactionId], references: [id])
  transactionId  String      @unique

  printedBy    User   @relation(fields: [printedById], references: [id])
  printedById  String
}
