# ─────────────────────────────────────────────
# Gosandy Company Ltd - Backend Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/gosandy_db"

# JWT Secret (use a long random string in production)
JWT_SECRET="gosandy-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="8h"

# Server
PORT=5000
NODE_ENV=development

# App
APP_NAME="Gosandy Company Ltd"
FRONTEND_URL="http://localhost:3000"
